<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Yuzu_Frontend.Desktop.Views;assembly=Yuzu_Frontend.Desktop"
             xmlns:avaloniaIcon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:sukiui="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:vm="clr-namespace:Yuzu_Frontend.Models;assembly=Yuzu_Frontend"
             x:Class="Yuzu_Frontend.Desktop.Views.MCServerManagerLogConsolePage"
             x:DataType="local:MCServerManagerLogConsolePage">

    <Grid Margin="24,20,24,24">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="MC服务端管理器日志控制台" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="查看和管理各服务端管理器的日志输出" Opacity="0.6" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="ClearLogsButton"
                            Click="ClearLogsButton_Click"
                            Classes="Flat Rounded"
                            Height="34"
                            FontSize="13">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <avaloniaIcon:MaterialIcon Kind="TrashCan" Width="16" Height="16" />
                            <TextBlock Text="清空日志" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="GetOlderLogsButton"
                            Click="GetOlderLogsButton_Click"
                            Classes="Flat Rounded"
                            Height="34"
                            FontSize="13"
                            IsEnabled="{Binding ViewModel.CanGetOlderLogs}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <avaloniaIcon:MaterialIcon Kind="Download" Width="16" Height="16" />
                            <TextBlock Text="加载更多" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <sukiui:GlassCard Grid.Row="1" Padding="0" IsAnimated="True">
                <Grid ColumnDefinitions="*,200" ColumnSpacing="0">
                    <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="0">
                        <Border Background="{DynamicResource ThemeCardLayerBackground}"
                                CornerRadius="12,0,0,0" Padding="16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                    <avaloniaIcon:MaterialIcon Kind="Search" Width="16" Height="16" Opacity="0.6" />
                                    <TextBox x:Name="FilterTextBox"
                                             Text="{Binding ViewModel.FilterText, Mode=TwoWay}"
                                             FontSize="13"
                                             PlaceholderText="搜索日志内容..." />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Click="ClearFilterButton_Click"
                                        Classes="Flat Rounded"
                                        Height="36"
                                        Width="36"
                                        IsVisible="{Binding ViewModel.HasFilter}">
                                    <avaloniaIcon:MaterialIcon Kind="Close" Width="16" Height="16" />
                                </Button>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Border x:Name="LoadingOverlay"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Background="{DynamicResource ThemeCardBackground}"
                                        Opacity="0.8"
                                        IsVisible="{Binding ViewModel.IsLoading}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                        <avaloniaIcon:MaterialIcon Kind="Refresh" Width="48" Height="48"
                                                               Foreground="{DynamicResource ThemeAccentBrush}" />
                                        <TextBlock Text="正在加载日志..." FontSize="14" Opacity="0.7" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="ErrorState"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Background="#FFF5F5"
                                        IsVisible="{Binding ViewModel.HasError}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                                                Margin="48">
                                        <avaloniaIcon:MaterialIcon Kind="AlertCircle" Width="64" Height="64"
                                                               Foreground="#FF6B6B" />
                                        <TextBlock Text="{Binding ViewModel.ErrorMessage}" FontSize="16" Opacity="0.6" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="EmptyState"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        IsVisible="{Binding ViewModel.IsEmpty}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                                                Margin="48">
                                        <avaloniaIcon:MaterialIcon Kind="FileText" Width="64" Height="64"
                                                               Opacity="0.3" />
                                        <TextBlock Text="请从右侧选择一个服务端管理器" FontSize="16" Opacity="0.6" />
                                    </StackPanel>
                                </Border>

                                <ListBox x:Name="LogListBox"
                                         Grid.Row="0"
                                         Grid.Column="0"
                                         ItemsSource="{Binding ViewModel.FilteredLogEntries}"
                                         IsVisible="{Binding ViewModel.HasLogs}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LogEntryModel">
                                            <Border Margin="0,0,0,2">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                    <Border Grid.Column="0" Padding="8,4">
                                                        <TextBlock Text="{Binding TimeText}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="12"
                                                                   Opacity="0.6"
                                                                   Width="150" />
                                                    </Border>
                                                    <Border Grid.Column="1" Padding="0,4,8,4">
                                                        <TextBlock Text="{Binding Content}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Column="1" Background="{DynamicResource ThemeCardLayerBackground}" CornerRadius="0,12,12,0">
                        <Grid RowDefinitions="Auto,*" RowSpacing="0">
                            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <avaloniaIcon:MaterialIcon Kind="Server" Width="16" Height="16" />
                                    <TextBlock Text="服务端管理器" FontSize="13" FontWeight="Medium" />
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ListBox x:Name="ManagerListBox"
                                         ItemsSource="{Binding ViewModel.ManagerList}"
                                         SelectedItem="{Binding ViewModel.SelectedManager, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MCServerManagerItemModel">
                                            <Border Margin="0,0,0,2">
                                                <StackPanel Orientation="Vertical" Margin="12,8">
                                                    <TextBlock Text="{Binding MCServerName}" FontSize="13" FontWeight="Medium" />
                                                    <TextBlock Text="{Binding ManagerId}" FontSize="11" Opacity="0.5" />
                                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                                        <Ellipse Width="8" Height="8"
                                                                 Fill="{Binding IsMCServerRunning, Converter={x:Static local:StatusColorConverter.Instance}}" />
                                                        <TextBlock Text="{Binding MCServerStatus}" FontSize="11" Opacity="0.6" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </sukiui:GlassCard>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <TextBlock Text="{Binding ViewModel.LogEntries.Count, StringFormat='共 {0} 条日志'}" FontSize="13" Opacity="0.6" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>