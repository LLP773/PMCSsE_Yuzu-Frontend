<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Yuzu_Frontend.Desktop.Views;assembly=Yuzu_Frontend.Desktop"
             xmlns:models="clr-namespace:Yuzu_Frontend.Models;assembly=Yuzu_Frontend"
             xmlns:avaloniaIcon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:sukiui="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             x:Class="Yuzu_Frontend.Desktop.Views.MCServerManagerConfigPage"
             x:DataType="models:MCServerManagerConfigViewModel">

    <Grid ColumnDefinitions="240,*" ColumnSpacing="0">
        <Border Grid.Column="0" Background="{DynamicResource ThemeCardLayerBackground}" CornerRadius="12,0,0,12">
            <Grid RowDefinitions="Auto,*">
                <Border Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="配置管理" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="Manager ID" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding ManagerId}" FontSize="14" FontFamily="Consolas" Foreground="{DynamicResource PrimaryTextBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="SectionList" 
                                 ItemsSource="{Binding SectionHeaders}"
                                 SelectedItem="{Binding ActiveSection, Mode=TwoWay}"
                                 SelectionMode="Single"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="12,8" />
                                    <Setter Property="Margin" Value="0,2" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.2">
                                            <KeyFrame Cue="0%">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                            </KeyFrame>
                                            <KeyFrame Cue="100%">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                <Setter Property="Foreground" Value="White" />
                                            </KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                                <Style Selector="ListBoxItem:selected">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                </Style>
                                <Style Selector="ListBoxItem:hover:not(:selected)">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryTextBrush}" /><Setter Property="Opacity" Value="0.2" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <avaloniaIcon:MaterialIcon x:Name="SectionIcon" Width="18" Height="18" />
                                        <TextBlock Text="{Binding}" FontSize="14" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ThemeBackground}" CornerRadius="0,12,12,0">
            <Grid RowDefinitions="Auto,*">
                <Border Background="{DynamicResource ThemeCardLayerBackground}" Padding="20">
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelChanges}"
                                IsEnabled="{Binding HasChanges}"
                                Margin="0"
                                Padding="12,6"
                                Background="Transparent"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <avaloniaIcon:MaterialIcon Kind="Refresh" Width="16" Height="16" />
                                <TextBlock Text="取消" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveConfig}"
                                IsEnabled="{Binding CanSave}"
                                Margin="0"
                                Padding="12,6"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="White"
                                CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <avaloniaIcon:MaterialIcon Kind="Download" Width="16" Height="16" />
                                <TextBlock Text="保存" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="ContentScrollViewer">
                    <StackPanel Spacing="0">
                        <sukiui:GlassCard x:Name="BasicSection" Margin="20,20,20,0" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{DynamicResource PrimaryBrush}" Opacity="0.2" Padding="8" CornerRadius="8">
                                        <avaloniaIcon:MaterialIcon Kind="Settings" Width="24" Height="24" Foreground="{DynamicResource PrimaryBrush}" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="基本设置" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="服务端核心配置" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="服务端名称" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBox Text="{Binding MCServerName}"
                                                 PlaceholderText="输入服务端名称"
                                                 Padding="12"
                                                 CornerRadius="8"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="服务端类型" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <ComboBox SelectedItem="{Binding MCServerType}"
                                                  Padding="12"
                                                  CornerRadius="8"
                                                  BorderThickness="1"
                                                  BorderBrush="{DynamicResource DividerBrush}">
                                            <ComboBoxItem Content="Vanilla" />
                                            <ComboBoxItem Content="Forge" />
                                            <ComboBoxItem Content="Fabric" />
                                            <ComboBoxItem Content="Spigot" />
                                            <ComboBoxItem Content="Paper" />
                                            <ComboBoxItem Content="Purpur" />
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="服务端目录" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox Text="{Binding MCServerDirectory}"
                                                     PlaceholderText="选择服务端目录"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}"
                                                     IsReadOnly="True" />
                                            <Button Click="BrowseServerDirectory"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White">
                                                <avaloniaIcon:MaterialIcon Kind="FolderOpen" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Java路径" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox Text="{Binding JavaPath}"
                                                     PlaceholderText="选择Java路径"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}"
                                                     IsReadOnly="True" />
                                            <Button Click="BrowseJavaPath"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White">
                                                <avaloniaIcon:MaterialIcon Kind="FolderOpen" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="启动参数" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBox Text="{Binding StartUpArguments}"
                                                 PlaceholderText="-Xmx2G -Xms1G"
                                                 Padding="12"
                                                 CornerRadius="8"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}"
                                                 AcceptsReturn="True"
                                                 Height="80" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </sukiui:GlassCard>

                        <sukiui:GlassCard x:Name="BackupSection" Margin="20,20,20,0" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{DynamicResource SecondaryBrush}" Opacity="0.2" Padding="8" CornerRadius="8">
                                        <avaloniaIcon:MaterialIcon Kind="BackupRestore" Width="24" Height="24" Foreground="{DynamicResource SecondaryBrush}" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="备份设置" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="自动备份与定时配置" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <TextBlock Text="启用自动备份" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <ToggleSwitch IsChecked="{Binding AutoBackupEnabled}"
                                                      Margin="0,0,0,0"
                                                      Width="48"
                                                      HorizontalAlignment="Right" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="备份定时模式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <ComboBox SelectedIndex="{Binding BackupTimingModeIndex}"
                                                  Padding="12"
                                                  CornerRadius="8"
                                                  BorderThickness="1"
                                                  BorderBrush="{DynamicResource DividerBrush}">
                                            <ComboBoxItem Content="间隔天数后特定时间" />
                                            <ComboBoxItem Content="固定时间间隔" />
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="12" IsVisible="{Binding BackupTimingMode, Converter={x:Static local:BackupModeConverter.Instance}, ConverterParameter=DayInterval_SpecificTime}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="间隔天数" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding DayInterval}"
                                                     PlaceholderText="1"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="特定时间" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding SpecificTime}"
                                                     PlaceholderText="04:00:00"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4" IsVisible="{Binding BackupTimingMode, Converter={x:Static local:BackupModeConverter.Instance}, ConverterParameter=FixedTimeInterval}">
                                        <TextBlock Text="时间间隔" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBox Text="{Binding TimeInterval}"
                                                 PlaceholderText="04:00:00"
                                                 Padding="12"
                                                 CornerRadius="8"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <TextBlock Text="备份前关服" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <ToggleSwitch IsChecked="{Binding StopServerBeforeBackup}"
                                                      Margin="0,0,0,0"
                                                      Width="48"
                                                      HorizontalAlignment="Right" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="备份模式" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <ComboBox SelectedIndex="{Binding BackupModeIndex}"
                                                  Padding="12"
                                                  CornerRadius="8"
                                                  BorderThickness="1"
                                                  BorderBrush="{DynamicResource DividerBrush}">
                                            <ComboBoxItem Content="全量备份" />
                                            <ComboBoxItem Content="文件级增量备份" />
                                            <ComboBoxItem Content="块级增量备份" />
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="压缩等级 (0-9)" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <Slider Minimum="0" Maximum="9" 
                                                Value="{Binding CompactionLevel, Mode=TwoWay}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                CornerRadius="8" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </sukiui:GlassCard>

                        <sukiui:GlassCard x:Name="ExclusionSection" Margin="20,20,20,0" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{DynamicResource WarningBrush}" Opacity="0.2" Padding="8" CornerRadius="8">
                                        <avaloniaIcon:MaterialIcon Kind="FilterList" Width="24" Height="24" Foreground="{DynamicResource WarningBrush}" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="备份排除" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="排除特定文件/文件夹/扩展名" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                <StackPanel Spacing="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="排除文件" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox Text="{Binding NewExcludedFile}"
                                                     PlaceholderText="输入文件名"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                            <Button Command="{Binding AddExcludedFile}"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White">
                                                <avaloniaIcon:MaterialIcon Kind="Plus" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                        <ListBox ItemsSource="{Binding ExcludedFilesList}"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}"
                                                 CornerRadius="8"
                                                 Height="100">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Spacing="8">
                                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                                            <Button Click="RemoveExcludedFile_Click"
                                                                    Tag="{Binding}"
                                                                    Padding="4"
                                                                    CornerRadius="4"
                                                                    Background="Transparent"
                                                                    Foreground="{DynamicResource ErrorBrush}">
                                                                <avaloniaIcon:MaterialIcon Kind="Close" Width="14" Height="14" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="排除扩展名" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox Text="{Binding NewExcludedExtension}"
                                                     PlaceholderText=".log"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                            <Button Command="{Binding AddExcludedExtension}"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White">
                                                <avaloniaIcon:MaterialIcon Kind="Plus" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                        <ListBox ItemsSource="{Binding ExcludedFileExtensionsList}"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}"
                                                 CornerRadius="8"
                                                 Height="100">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Spacing="8">
                                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                                            <Button Click="RemoveExcludedExtension_Click"
                                                                    Tag="{Binding}"
                                                                    Padding="4"
                                                                    CornerRadius="4"
                                                                    Background="Transparent"
                                                                    Foreground="{DynamicResource ErrorBrush}">
                                                                <avaloniaIcon:MaterialIcon Kind="Close" Width="14" Height="14" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="排除文件夹" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox Text="{Binding NewExcludedFolder}"
                                                     PlaceholderText="world/nether"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                            <Button Command="{Binding AddExcludedFolder}"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White">
                                                <avaloniaIcon:MaterialIcon Kind="Plus" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                        <ListBox ItemsSource="{Binding ExcludedFoldersList}"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}"
                                                 CornerRadius="8"
                                                 Height="100">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Spacing="8">
                                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                                            <Button Click="RemoveExcludedFolder_Click"
                                                                    Tag="{Binding}"
                                                                    Padding="4"
                                                                    CornerRadius="4"
                                                                    Background="Transparent"
                                                                    Foreground="{DynamicResource ErrorBrush}">
                                                                <avaloniaIcon:MaterialIcon Kind="Close" Width="14" Height="14" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </sukiui:GlassCard>

                        <sukiui:GlassCard x:Name="RemoteBackupSection" Margin="20,20,20,0" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{DynamicResource AccentBrush}" Opacity="0.2" Padding="8" CornerRadius="8">
                                        <avaloniaIcon:MaterialIcon Kind="CloudUpload" Width="24" Height="24" Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="远程备份" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="SFTP远程备份配置" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="本地备份输出目录" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox Text="{Binding BackupFileOutputDirectory}"
                                                     PlaceholderText="选择备份目录"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}"
                                                     IsReadOnly="True" />
                                            <Button Click="BrowseBackupDirectory"
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Foreground="White">
                                                <avaloniaIcon:MaterialIcon Kind="FolderOpen" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <TextBlock Text="启用SFTP远程备份" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <ToggleSwitch IsChecked="{Binding SFTPEnabled}"
                                                      Margin="0,0,0,0"
                                                      Width="48"
                                                      HorizontalAlignment="Right" />
                                    </StackPanel>

                                    <StackPanel Spacing="12" IsVisible="{Binding SFTPEnabled}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="远程备份存放目录" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding RemoteBackupFileStoreDirectory}"
                                                     PlaceholderText="/backups"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SFTP主机地址" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding SFTPHost}"
                                                     PlaceholderText="127.0.0.1"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SFTP端口" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding SFTPPort}"
                                                     PlaceholderText="22"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SFTP用户名" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding SFTPUserName}"
                                                     PlaceholderText="username"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="SFTP密码" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding SFTPPassword}"
                                                     PlaceholderText="password"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="缓冲区大小 (MiB)" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBox Text="{Binding SFTPBufferSize}"
                                                     PlaceholderText="1"
                                                     Padding="12"
                                                     CornerRadius="8"
                                                     BorderThickness="1"
                                                     BorderBrush="{DynamicResource DividerBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </sukiui:GlassCard>

                        <sukiui:GlassCard x:Name="ChatSection" Margin="20,20,20,20" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{DynamicResource SuccessBrush}" Opacity="0.2" Padding="8" CornerRadius="8">
                                        <avaloniaIcon:MaterialIcon Kind="ChatBubble" Width="24" Height="24" Foreground="{DynamicResource SuccessBrush}" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="在线聊天" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="聊天服务器配置" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="服务器端口" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBox Text="{Binding ServerPort}"
                                                 PlaceholderText="8080"
                                                 Padding="12"
                                                 CornerRadius="8"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="第三方社交平台" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBox Text="{Binding ThirdPartySocialPlatformName}"
                                                 PlaceholderText="Discord"
                                                 Padding="12"
                                                 CornerRadius="8"
                                                 BorderThickness="1"
                                                 BorderBrush="{DynamicResource DividerBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </sukiui:GlassCard>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>